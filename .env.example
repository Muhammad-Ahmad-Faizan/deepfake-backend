# MongoDB Connection String
# Local: mongodb://localhost:27017/deepfake_db
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=ClusterName
DATABASE_URL=mongodb://localhost:27017/deepfake_db

# API Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials (CHANGE IN PRODUCTION!)
ADMIN_EMAIL=admin@deepfake.com
ADMIN_PASSWORD=admin123

# CORS & External URLs
CORS_ORIGINS=http://localhost:3000
MODEL_API_URL=http://localhost:5000
MODEL_API_URLS=

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
