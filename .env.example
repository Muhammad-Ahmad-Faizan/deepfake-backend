# Database
# Use your Neon.tech connection string in production.
DATABASE_URL=sqlite:///./deepfake_detection.db

# JWT Settings
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@deepfake.com
ADMIN_PASSWORD=admin123

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600

# CORS / Service URLs
CORS_ORIGINS=http://localhost:3000
MODEL_API_URL=http://localhost:5000
MODEL_API_URLS=default=http://localhost:5000,final_model=http://localhost:5000,fast=http://localhost:5000
